      "regex": "^/api/generate/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPgenerationId": "nxtPgenerationId"
      },
      "namedRegex": "^/api/generate/(?<nxtPgenerationId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/roof-measure/measurements/[id]",
      "regex": "^/api/roof\\-measure/measurements/([^/]+?)(?:/)?$",
