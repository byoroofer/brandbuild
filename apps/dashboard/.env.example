# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional newer Supabase public key names. Use one public key variant only.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Optional for admin-only server workflows and storage mirroring.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI / Sora
OPENAI_API_KEY=

# Optional. Defaults to sora-2. Supported values: sora-2, sora-2-pro
# OPENAI_SORA_MODEL=sora-2

# Optional. Studio Agent model.
# OPENAI_STUDIO_AGENT_MODEL=gpt-5.1-codex

# Optional. Dashboard tag discovery model.
# OPENAI_TAG_DISCOVERY_MODEL=gpt-5-mini

# Optional. Voice note transcription model.
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Kling
KLING_API_KEY=
KLING_API_SECRET=

# Optional Kling overrides
# KLING_API_BASE_URL=https://api-singapore.klingai.com
# KLING_API_CREATE_PATH=/v1/videos/text2video
# KLING_API_STATUS_PATH_TEMPLATE=/v1/videos/text2video/{jobId}
# KLING_API_MODEL_NAME=kling-v2-6
# KLING_API_MODE=std
# KLING_API_SOUND_MODE=off
# KLING_API_TOKEN_TTL_SECONDS=1800

# Higgsfield
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=

# Optional combined auth header value
# HF_KEY=your_api_key:your_api_key_secret

# Optional Higgsfield overrides
# HIGGSFIELD_API_BASE_URL=https://platform.higgsfield.ai
# HIGGSFIELD_MODEL_ID=higgsfield-ai/dop/standard
# HIGGSFIELD_RESOLUTION=720p
# HIGGSFIELD_DURATION_SECONDS=5
# HIGGSFIELD_WEBHOOK_URL=

# App
NEXT_PUBLIC_APP_NAME=BrandBuild
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=support@brandbuild.online

# Branded auth email links rely on NEXT_PUBLIC_APP_URL and these frontend routes:
# /auth/confirm
# /auth/callback
# /reset-password

# Supabase Send Email Hook secrets are configured separately in:
# supabase/functions/.env.example

# Storage
STORAGE_BUCKET_ASSETS=assets
STORAGE_BUCKET_EXPORTS=exports

# Optional
FFMPEG_PATH=ffmpeg

# Existing optional repo variables used by legacy routes still present in this workspace.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
GOOGLE_GEOCODING_API_KEY=
NEXT_PUBLIC_ENABLE_GUEST_MODE=true
