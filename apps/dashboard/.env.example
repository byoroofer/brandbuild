# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional newer Supabase public key name. Either this or NEXT_PUBLIC_SUPABASE_ANON_KEY works.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase's current generated Next.js snippets may use this name instead.
# Either this, NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY, or NEXT_PUBLIC_SUPABASE_ANON_KEY works.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Optional for future admin-only workflows. Normal operator reads/writes use authenticated sessions.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI / Sora
OPENAI_API_KEY=

# Optional. Defaults to sora-2. Supported values: sora-2, sora-2-pro
# OPENAI_SORA_MODEL=sora-2

# Optional. Studio Agent model. Use gpt-5.1-codex for a Codex-backed operator agent,
# or switch to gpt-5.4 if you want the flagship general reasoning model instead.
# OPENAI_STUDIO_AGENT_MODEL=gpt-5.1-codex

# Optional. Dashboard tag discovery model. Defaults to gpt-5-mini for fast web-backed scans.
# OPENAI_TAG_DISCOVERY_MODEL=gpt-5-mini

# Optional. Voice note transcription model for tag discovery. Defaults to gpt-4o-mini-transcribe.
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Legacy fallback for older internal Sora wiring:
# SORA_API_KEY=

# Kling
KLING_API_KEY=
KLING_API_SECRET=

# Optional Kling overrides. The defaults target the current global API surface.
# KLING_API_BASE_URL=https://api-singapore.klingai.com
# KLING_API_CREATE_PATH=/v1/videos/text2video
# KLING_API_STATUS_PATH_TEMPLATE=/v1/videos/text2video/{jobId}
# KLING_API_MODEL_NAME=kling-v2-6
# KLING_API_MODE=std
# KLING_API_SOUND_MODE=off
# KLING_API_TOKEN_TTL_SECONDS=1800

# Higgsfield
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=

# Optional combined auth header value if you prefer storing one secret:
# HF_KEY=your_api_key:your_api_key_secret

# Optional Higgsfield overrides. The defaults target Higgsfield's current platform API.
# HIGGSFIELD_API_BASE_URL=https://platform.higgsfield.ai
# HIGGSFIELD_MODEL_ID=higgsfield-ai/dop/standard
# HIGGSFIELD_RESOLUTION=720p
# HIGGSFIELD_DURATION_SECONDS=5
# HIGGSFIELD_WEBHOOK_URL=

# App
NEXT_PUBLIC_APP_NAME=AI Video Studio
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Recommended to set to your custom production domain.
# On Vercel, the app can also fall back to VERCEL_PROJECT_PRODUCTION_URL or VERCEL_URL.

# Storage
STORAGE_BUCKET_ASSETS=assets
STORAGE_BUCKET_EXPORTS=exports

# The asset bucket should exist before live output mirroring is enabled.
# Successful live provider outputs are mirrored only when SUPABASE_SERVICE_ROLE_KEY is also set.

# Optional
FFMPEG_PATH=ffmpeg

# Existing optional repo variables used by legacy routes still present in this workspace.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
GOOGLE_GEOCODING_API_KEY=
NEXT_PUBLIC_ENABLE_GUEST_MODE=true
