# Supabase Send Email Hook secrets
SEND_EMAIL_HOOK_SECRET=

# Branded auth email identity
AUTH_EMAIL_APP_NAME=BrandBuild
AUTH_EMAIL_FROM_NAME=BrandBuild
AUTH_EMAIL_FROM_EMAIL=no-reply@brandbuild.online
AUTH_EMAIL_REPLY_TO=support@brandbuild.online
AUTH_SUPPORT_EMAIL=support@brandbuild.online
AUTH_EMAIL_SITE_URL=http://localhost:3000
AUTH_EMAIL_LOGO_URL=http://localhost:3000/brandbuild-logo.svg

# SMTP provider used by the Supabase send-auth-email hook
AUTH_EMAIL_SMTP_HOST=
AUTH_EMAIL_SMTP_PORT=587
AUTH_EMAIL_SMTP_SECURE=false
AUTH_EMAIL_SMTP_USER=
AUTH_EMAIL_SMTP_PASSWORD=
